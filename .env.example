# Copy this file to .env and fill in a real value. .env is gitignored - never commit it.

# GitHub Personal Access Token used by scripts/setup-github-mcp.sh to register
# the GitHub MCP server for this project. Needs at least `repo` scope; add
# `project` scope too if Product_Owner should manage GitHub Projects fields
# (not just create/move issues). Create one at:
# https://github.com/settings/personal-access-tokens/new
GITHUB_PAT=
